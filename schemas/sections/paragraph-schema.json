{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Paragraph Section Schema",
  "type": "object",
  "required": ["schemaId", "content"],
  "properties": {
    "schemaId": {
      "type": "string",
      "description": "Unique identifier for the paragraph schema"
    },
    "schemaVersion": {
      "type": "string",
      "default": "1.0.0",
      "description": "Version of the schema definition"
    },
    "content": {
      "type": "string",
      "description": "Text content of the paragraph"
    },
    "formatting": {
      "type": "object",
      "properties": {
        "bold": {
          "type": "boolean",
          "default": false,
          "description": "Whether text is bold"
        },
        "italic": {
          "type": "boolean",
          "default": false,
          "description": "Whether text is italic"
        },
        "underline": {
          "type": "boolean",
          "default": false,
          "description": "Whether text is underlined"
        },
        "fontSize": {
          "type": "integer",
          "minimum": 6,
          "maximum": 72,
          "default": 12,
          "description": "Font size in points"
        },
        "fontFamily": {
          "type": "string",
          "default": "Arial",
          "description": "Font family"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#000000",
          "description": "Text color in hex format"
        },
        "alignment": {
          "type": "string",
          "enum": ["left", "center", "right", "justify"],
          "default": "left",
          "description": "Text alignment"
        },
        "lineSpacing": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 3.0,
          "default": 1.0,
          "description": "Line spacing multiplier"
        },
        "paragraphSpacing": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Spacing after paragraph in points"
        }
      }
    },
    "position": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "description": "X position in points"
        },
        "y": {
          "type": "number",
          "description": "Y position in points"
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "description": "Width in points"
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "description": "Height in points"
        }
      }
    },
    "margins": {
      "type": "object",
      "properties": {
        "top": {
          "type": "integer",
          "default": 0,
          "description": "Top margin in points"
        },
        "right": {
          "type": "integer",
          "default": 0,
          "description": "Right margin in points"
        },
        "bottom": {
          "type": "integer",
          "default": 0,
          "description": "Bottom margin in points"
        },
        "left": {
          "type": "integer",
          "default": 0,
          "description": "Left margin in points"
        }
      }
    },
    "border": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether border is enabled"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#000000",
          "description": "Border color in hex format"
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Border width in points"
        },
        "style": {
          "type": "string",
          "enum": ["solid", "dashed", "dotted", "double"],
          "default": "solid",
          "description": "Border style"
        }
      }
    },
    "background": {
      "type": "object",
      "properties": {
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "Background color in hex format"
        },
        "transparency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0,
          "description": "Background transparency (0 = opaque, 1 = transparent)"
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum character length"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum character length"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for content validation"
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "Whether content is required"
        }
      }
    }
  }
}
