{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Table Section Schema",
  "type": "object",
  "required": ["schemaId", "columns"],
  "properties": {
    "schemaId": {
      "type": "string",
      "description": "Unique identifier for the table schema"
    },
    "schemaVersion": {
      "type": "string",
      "default": "1.0.0",
      "description": "Version of the schema definition"
    },
    "tableName": {
      "type": "string",
      "default": "",
      "description": "Name of the table"
    },
    "dimensions": {
      "type": "object",
      "properties": {
        "minRows": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "maxRows": {
          "type": "integer",
          "minimum": 1,
          "default": 1000
        },
        "defaultRows": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "columnCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique column identifier"
          },
          "name": {
            "type": "string",
            "description": "Display name of the column"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "date", "enum"],
            "description": "Data type of the column"
          },
          "required": {
            "type": "boolean",
            "default": false,
            "description": "Whether the column is required"
          },
          "editable": {
            "type": "boolean",
            "default": true,
            "description": "Whether the column is editable"
          },
          "sortable": {
            "type": "boolean",
            "default": true,
            "description": "Whether the column can be sorted"
          },
          "filterable": {
            "type": "boolean",
            "default": true,
            "description": "Whether the column can be filtered"
          },
          "width": {
            "type": "integer",
            "minimum": 40,
            "default": 120,
            "description": "Width of the column in pixels"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Options for enum type columns"
          },
          "format": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["text", "currency", "percentage", "date"],
                "default": "text",
                "description": "Format kind for display"
              },
              "currencyCode": {
                "type": "string",
                "default": "USD",
                "description": "Currency code for currency format"
              },
              "precision": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10,
                "default": 2,
                "description": "Decimal precision for numbers"
              }
            }
          }
        }
      }
    },
    "rows": {
      "type": "object",
      "properties": {
        "rowIdStrategy": {
          "type": "string",
          "enum": ["auto", "manual"],
          "default": "auto",
          "description": "Strategy for generating row IDs"
        },
        "allowAdd": {
          "type": "boolean",
          "default": true,
          "description": "Whether new rows can be added"
        },
        "allowDelete": {
          "type": "boolean",
          "default": true,
          "description": "Whether rows can be deleted"
        },
        "allowReorder": {
          "type": "boolean",
          "default": false,
          "description": "Whether rows can be reordered"
        },
        "showRowNumbers": {
          "type": "boolean",
          "default": false,
          "description": "Whether to show row numbers"
        }
      }
    },
    "validationSchema": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "minLength": {
            "type": "integer",
            "description": "Minimum length for string values"
          },
          "maxLength": {
            "type": "integer",
            "description": "Maximum length for string values"
          },
          "pattern": {
            "type": "string",
            "description": "Regex pattern for validation"
          },
          "min": {
            "type": "number",
            "description": "Minimum value for numbers"
          },
          "max": {
            "type": "number",
            "description": "Maximum value for numbers"
          },
          "allowedValues": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Allowed values for validation"
          }
        }
      },
      "default": {}
    },
    "behaviorSchema": {
      "type": "object",
      "properties": {
        "sorting": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether sorting is enabled"
            },
            "multiColumn": {
              "type": "boolean",
              "default": false,
              "description": "Whether multi-column sorting is allowed"
            }
          }
        },
        "filtering": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether filtering is enabled"
            }
          }
        },
        "pagination": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether pagination is enabled"
            },
            "pageSize": {
              "type": "integer",
              "default": 10,
              "description": "Number of rows per page"
            }
          }
        },
        "editing": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Whether editing is enabled"
            },
            "mode": {
              "type": "string",
              "enum": ["cell", "row"],
              "default": "cell",
              "description": "Editing mode"
            }
          }
        }
      }
    }
  }
}
