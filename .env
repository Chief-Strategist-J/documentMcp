# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5433/document_management
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_documents
DB_USER=test
DB_PASSWORD=test

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# API Configuration
API_KEY=test-api-key
API_BASE_URL=http://localhost:3000

# MCP Configuration
MCP_SERVER_PORT=3001

# Document Generation
DOCUMENT_OUTPUT_DIR=./generated-documents

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100
