{
  "name": "document-management-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for document management with REST API and PostgreSQL",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node scripts/build-optimized.js",
    "build:fast": "node scripts/build-optimized.js",
    "build:clean": "node scripts/build-optimized.js --clean",
    "build:watch": "tsc --incremental --watch",
    "build:tsc": "tsc --incremental",
    "cache:clear": "node scripts/build-optimized.js clear",
    "cache:stats": "node scripts/build-optimized.js stats",
    "dev": "ts-node-dev --respawn --transpile-only --clear src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "mcp:build": "tsc mcp/server.ts --outDir dist/mcp",
    "mcp:start": "node dist/mcp/mcp/server.js",
    "mcp:dev": "ts-node mcp/server.ts",
    "mcp:test": "npm run test -- --testPathPattern=mcp",
    "mcp:docker:build": "docker build -f Dockerfile.mcp -t document-management-mcp .",
    "mcp:docker:run": "docker run -it --rm document-management-mcp",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "keywords": [
    "document",
    "sdk",
    "typescript",
    "api",
    "postgresql",
    "word",
    "pdf"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@types/uuid": "^9.0.1",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/cors": "^2.8.19",
    "@types/supertest": "^7.2.0",
    "ajv": "^8.12.0",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "express": "^4.18.2",
    "pg-promise": "^12.6.2",
    "puppeteer": "^19.8.0",
    "supertest": "^7.2.2",
    "uuid": "^9.0.0"
  }
}
